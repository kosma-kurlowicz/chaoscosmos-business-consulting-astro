---
import { Card, Heading, Link } from 'accessible-astro-components'
import { Icon } from 'astro-icon/components'
import { getCollection } from 'astro:content'
import { slugify } from '@/utils/slugify'

// Import images directly for optimization
import projectImage01 from '@assets/images/projects/roi/chaoscosmos-roi2023-mockup-cover-w2560.webp'
import projectImage02 from '@assets/images/projects/interior/chaoscosmos-interior-mockup-cover-w2560.webp'
import projectImage03 from '@assets/images/projects/symbiosis-planner/chaoscosmos-symbiosis2019-mockup-planner-cover-w2560.webp'
import projectImage04 from '@assets/images/projects/antilica-jungle/chaoscosmos-antilica-photo-4.webp'
import projectImage05 from '@assets/images/projects/veganetti-website/chaoscosmos-veganetti-website-w1920.webp'
import projectImage06 from '@assets/images/projects/mj-website/chaoscosmos-mj-website-1-w2560.webp'
import projectImage07 from '@assets/images/projects/antilica-website/chaoscosmos-antilica-website-1-w2560.webp'
import projectImage08 from '@assets/images/projects/mobilum-website/chaoscosmos-mobilum-website-1-w2560.webp'
import projectImage09 from '@assets/images/projects/artt-website/chaoscosmos-website-artt-w2560.webp'
import projectImage10 from '@assets/images/projects/kaid/chaoscosmos-kaid-intro.webp'
import projectImage11 from '@assets/images/projects/acsr-website/chaoscosmos-acsr-website-1-w2560.webp'
import projectImage12 from '@assets/images/projects/glosno-website/chaoscosmos-website-glosno-1-w2560.webp'
import projectImage13 from '@assets/images/projects/gp-website/chaoscosmos-website-gp-1-w2560.webp'
import projectImage14 from '@assets/images/projects/cm-website/chaoscosmos-website-cm-1-w2560.webp'
import projectImage15 from '@assets/images/projects/cbk-website/chaoscosmos-website-cbk-1-w2560.webp'

/**
 * FeaturedProjects Component
 *
 * @description A component that displays featured projects from Astro Content Collections
 */
interface Props {
  /**
   * Additional classes to apply to the section
   */
  class?: string
  /**
   * The number of projects to display
   * @default 6
   */
  limit?: number
  /**
   * The title for the section
   * @default "Featured projects"
   */
  title?: string
}

const { class: className, limit = 3, title = 'Wybrane projekty' } = Astro.props

// Get projects from content collection
const projects = await getCollection('projects')
const projectImages = [projectImage01, projectImage02, projectImage03, projectImage04, projectImage05, projectImage06, projectImage07, projectImage08, projectImage09, projectImage10, projectImage11, projectImage12, projectImage13, projectImage14, projectImage15]

// Limit projects and add featured images
const featuredProjects = projects.slice(0, limit).map((project, index) => ({
  ...project,
  // slug from frontmatter or title
  slug: project.data.slug ?? slugify(project.data.title),
  featuredImage: projectImages[index % projectImages.length],
}))
---

<section class:list={[className, 'my-32 md:my-64']}>
  <div class="container">
    <Heading level="h2" class="mb-6">{title}</Heading>
    <div class="grid grid-cols-1 gap-12 md:grid-cols-2 lg:grid-cols-3">
      {
        featuredProjects.map((project) => (
          <Card
            imageComponent={project.featuredImage}
            url={'/portfolio/' + project.slug}
            headingLevel="h2"
            title={project.data.title}
            footer={'Klient: ' + project.data.client}
            class="gsapanim  bg-[var(--card-background-color)] rounded-lg lg:rounded-bl-4xl"
          >
            {project.data.description}
          </Card>
        ))
      }
    </div>
    <div class="mt-12">
      <Link href="/portfolio/" isButton animateOnHover animationType="nudge">
        Zobacz wszystkie projekty
        <Icon aria-hidden="true" name="lucide:arrow-right" size="1.5rem" />
      </Link>
    </div>
  </div>
</section>

<style lang="scss">
  .card {
    border-width: 1px;
    border-color: oklch(0.21 0.034 264.665);
  }
</style>