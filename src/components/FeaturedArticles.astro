---
import { Card, Heading, Link } from 'accessible-astro-components'
import { Icon } from 'astro-icon/components'
import { getCollection } from 'astro:content'
import { slugify } from '@/utils/slugify'

// Import images directly for optimization
import projectImage1 from '@assets/images/articles/article-1-vanilla-factory-disorted-scaled.webp'
import projectImage2 from '@assets/images/articles/civil-war/vlcsnap-2024-12-12-00h24m38s240.webp'
import projectImage3 from '@assets/images/articles/filmowo-2025/Screenshot-2024-12-31-182203.webp'
import projectImage4 from '@assets/images/articles/bharat/624840718_4404594813149944_3124348101418873352_n.webp'
import projectImage5 from '@assets/images/articles/diesel-s26/Screenshot 2026-03-17 001025.webp'
import projectImage6 from '@assets/images/articles/diesel-lidl/Screenshot 2026-03-21 175101.webp'


/**
 * Featured articles Component
 *
 * @description A component that displays featured articles from Astro Content Collections
 */
interface Props {
  /**
   * Additional classes to apply to the section
   */
  class?: string
  /**
   * The number of projects to display
   * @default 3
   */
  limit?: number
  /**
   * The title for the section
   * @default "Featured articles"
   */
  title?: string
}

const { class: className, limit = 3, title = 'Artykuły' } = Astro.props

// Get articles from content collection
const articles = await getCollection('articles')
const projectImages = [projectImage1, projectImage2, projectImage3, projectImage4, projectImage5, projectImage6]

const articlesReversed = articles.reverse()
const projectImagesReversed = projectImages.reverse()

// Limit projects and add featured images
const featuredArticles = articlesReversed.slice(0, limit).map((article, index) => ({
  ...article,
  // slug for article title or explicit frontmatter `slug`
  slug: article.data.slug ?? slugify(article.data.title),
  featuredImage: projectImagesReversed[index % projectImagesReversed.length],
}))
---

<section class:list={[className, 'my-32 md:my-64']}>
  <div class="container">
    <Heading level="h2" class="mb-6">{title}</Heading>
    <div class="grid grid-cols-1 gap-12 md:grid-cols-2 lg:grid-cols-3">
      {
        featuredArticles.map((article) => (
          <Card
            imageComponent={article.featuredImage}
            url={'/blog/' + article.slug}
            headingLevel="h2"
            title={article.data.title}
            footer={'Author: ' + article.data.author}
            class="gsapanim"
          >
            {article.data.description}
          </Card>
        ))
      }
    </div>
    <div class="mt-12">
      <Link href="/blog/" isButton animateOnHover animationType="nudge">
        View all articles
        <Icon aria-hidden="true" name="lucide:arrow-right" size="1.5rem" />
      </Link>
    </div>
  </div>
</section>
