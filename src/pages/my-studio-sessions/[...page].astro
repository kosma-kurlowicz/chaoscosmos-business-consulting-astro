---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import PageHeader from '@components/PageHeader.astro'
import { Badge, Card, Heading, Link, Pagination } from 'accessible-astro-components'
import { getCollection } from 'astro:content'
import type { GetStaticPaths, Page } from 'astro'
import type { CollectionEntry } from 'astro:content'
import { slugify } from '@/utils/slugify'

// Import images directly for optimization
import sessionImage01 from '@assets/images/sessions/veganetti-summer/veganetti-rame-di-napoli_IGP9412-v2-h1200.webp'
import sessionImage02 from '@assets/images/sessions/adidas/pexels-kosma-kurlowicz-1051820-2029355-scaled.webp'
import sessionImage03 from '@assets/images/sessions/cheesecake-traditional/pexels-kosma-kurlowicz-1051820-2029645.webp'
import sessionImage04 from '@assets/images/sessions/winter-solstice/kosma-kurlowicz-chaos-cosmos-winter-dead-no4_DSC3886-h1920.webp'
import sessionImage05 from '@assets/images/sessions/stardust/chaoscosmos-glam-cosmic-matter_DSC4399-h1920.webp'
import sessionImage06 from '@assets/images/sessions/rhubarb/chaoscosmos-rabarbar-rose-chafer-v11.webp'
import sessionImage07 from '@assets/images/sessions/old-masters/chaoscosmos_7up-full-DSC2859-h2400.webp'


export const getStaticPaths = (async ({ paginate }) => {
  const sessions = await getCollection('sessions')
  const allTags = sessions.map((session) => session.data.tags).flat()
  const uniqueTagLabels = [...new Set(allTags)].sort((a, b) => a.localeCompare(b))
  const uniqueTags = uniqueTagLabels.map((label) => ({
    label,
    slug: slugify(label),
  }))

  const sessionImages = [sessionImage01, sessionImage02, sessionImage03, sessionImage04, sessionImage05, sessionImage06, sessionImage07]

  const sessionsWithImages = sessions.map((session, index) => {
    return {
      ...session,
      // slug from frontmatter or title
      slug: session.data.slug ?? slugify(session.data.title),
      featuredImage: sessionImages[index % sessionImages.length],
    }
  })

  return paginate(sessionsWithImages, {
    pageSize: 6,
    props: { uniqueTags },
  })
}) satisfies GetStaticPaths

interface Props {
  page: Page<CollectionEntry<'sessions'> & { featuredImage: any; slug?: string }>
  uniqueTags: { label: string; slug: string }[]
}

const { page, uniqueTags } = Astro.props

console.log(page.lastPage)
---

<DefaultLayout
  title="Sesje z mojego studia"
  description=""
>
  <PageHeader
    title="Sesje z mojego studia"
    subtitle=''
    bgType="bordered"
  />
  <section class="my-12">
    <div class="container">
      <Heading level="h2" size="h5" class="mb-2">Tagi</Heading>
      <div class="flex flex-wrap gap-4">
        {
          uniqueTags.map((tag: { label: string; slug: string }) => (
            <Link href={'/my-studio-sessions/tag/' + tag.slug}>{tag.label}</Link>
          ))
        }
      </div>
      <p class="mt-8 text-sm">
        <em>Sesja {page.start + 1} do {page.end + 1} z {page.total} wszystkich sesji</em>
      </p>
      <ul class="mt-3 grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
        {
          page.data.map((session) => (
            <li>
              <Card
                imageComponent={session.featuredImage}
                url={'/my-studio-sessions/' + session.slug}
                title={session.data.title}
                headingLevel="h2"
                footer={'Klient: ' + session.data.author}
                fullHeight={true}
                class="gsapanim border bg-[var(--card-background-color)] rounded-lg lg:rounded-bl-4xl"
              >
                <span slot="meta">
                  {session.data.tags.map((tag) => (
                    <Badge>{tag}</Badge>
                  ))}
                </span>
                {session.data.description}
              </Card>
            </li>
          ))
        }
      </ul>
      {
        page && page.lastPage > 1 && (
          <div class="mt-12 grid place-content-center">
            <Pagination
              firstPage={page.url.prev ? '/my-studio-sessions' : null}
              previousPage={page.url.prev ? page.url.prev : null}
              nextPage={page.url.next ? page.url.next : null}
              lastPage={page.url.next ? `/my-studio-sessions/${page.lastPage}` : null}
              currentPage={`${page.currentPage}`}
              totalPages={`${page.lastPage}`}
              ariaLabel="Portfolio pagination"
            />
          </div>
        )
      }
    </div>
  </section>
</DefaultLayout>
