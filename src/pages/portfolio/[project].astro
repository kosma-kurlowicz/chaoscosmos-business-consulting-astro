---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import PageHeader from '@components/PageHeader.astro'
import SocialShares from '@components/SocialShares.astro'
import { Heading } from 'accessible-astro-components'
import { getCollection, render } from 'astro:content'
import { slugify } from '@/utils/slugify'
import type { CollectionEntry } from 'astro:content'

export async function getStaticPaths() {
  const projects = await getCollection('projects')

  const projectImages = [
    { src: '/projects/project-image-1.png' },
    { src: '/projects/project-image-2.png' },
    { src: '/projects/project-image-3.png' },
    { src: '/projects/project-image-4.png' },
    { src: '/projects/project-image-5.png' },
    { src: '/projects/project-image-6.png' },
  ]

  return projects.map((project, index) => {
    const projectSlug = project.data.slug ?? slugify(project.data.title)
    const projectWithImage = {
      ...project,
      featuredImage: projectImages[index % projectImages.length].src,
      slug: projectSlug,
    }

    return {
      params: { project: projectSlug },
      props: { project: projectWithImage, slug: projectSlug },
    }
  })
}

interface Props {
  project: CollectionEntry<'projects'> & { featuredImage: string; slug?: string }
}

const { project } = Astro.props
const { Content } = await render(project)

const client = {
  name: project.data.client,
  image: '/projects/project-image-1.png',
  bio: 'Klient',
}
---

<DefaultLayout title={project.data.title} description={project.data.description} url={`/portfolio/${project.slug}`}>
  <PageHeader
    title={project.data.title}
    subtitle={project.data.description}
    author={client}
    bgType="bordered"
    featuredImage={project.featuredImage}
  />
  <section class="my-12">
    <div class="narrow space-content container">
      <Content />
    </div>
  </section>
</DefaultLayout>

<style lang="scss" is:global>
  .narrow {
    margin-inline: auto;
    max-width: 65ch;
  }
</style>
